n = int(input("enter the number:"))
f1 = 0
f2 = 1

if n <= 0:
    print("Please enter a positive integer")
elif n == 1:
    print("Fibonacci sequence up to", n, ":")
    print(f1)
else:
    print("Fibonacci sequence up to", n, ":")
    print(f1)
    print(f2)
    for i in range(2, n):
        next_fib = f1 + f2
        print(next_fib)
        f1 = f2
        f2 = next_fib
